---
interface Props {
    id?: string;
    type?: "text" | "email" | "password" | "number";
    size?: "md" | "lg" | "sm" | "xl";
    placeholder?: string;
}

const { 
    id = "",
    size = "md",
    type = "text",
    placeholder = "",
} = Astro.props as Props;
---

<input
    id={id}
    type={type}
    placeholder={placeholder}
    class={`rounded-full text-foreground font-medium focus:outline-none ring focus:ring-2 focus:ring-foreground px-4 py-2 ${size === "sm" ? "px-3 py-1 text-sm" : size === "lg" ? "px-6 py-3 text-lg" : size === "xl" ? "px-8 py-4 text-xl" : "px-4 py-2 text-md" }`}
/>
