---
interface Props {
    variant?: ButtonVariant;
    href?: string;
    class?: string;
    size?: "md" | "lg" | "sm" | "xl";
    target?: string;
}

type ButtonVariant = "primary" | "secondary";

const { 
    href = "", 
    size = "md",
    class : className = "",
    target = "_self"
} = Astro.props as Props;

---

<a
    href={href}
    target={target}
    class={`bg-foreground hover:shadow-[0px_0px_30px_14px] shadow-[0px_0px_30px_7px] hover:shadow-white/50 shadow-white/50 text-black px-4 py-2 rounded-full text-sm font-medium hover:bg-slate-100 transition duration-300 cursor-pointer ${size === "sm" ? "px-2 py-1 text-xs" : size === "lg" ? "px-6 py-3 text-lg" : size === "xl" ? "px-8 py-4 text-xl" : "px-4 py-2 text-sm" } ${className}`}
>
    <slot/>
</a>
