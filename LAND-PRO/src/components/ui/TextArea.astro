---
interface Props {
    id?: string;
    size?: "md" | "lg" | "sm" | "xl";
    placeholder?: string;
    className?: string;
}

const { 
    id = "",
    size = "md",
    placeholder = "",
    className = "",
} = Astro.props as Props;
---

<textarea
    id={id}
    placeholder={placeholder}
    class={`rounded-4xl text-foreground font-medium focus:outline-none ring focus:ring-2 focus:ring-foreground px-4 py-2 backdrop-blur-md backdrop-saturate-150 ${size === "sm" ? "px-3 py-1 text-sm" : size === "lg" ? "px-6 py-3 text-lg" : size === "xl" ? "px-8 py-4 text-xl" : "px-4 py-2 text-md" } ${className}`}
/>
