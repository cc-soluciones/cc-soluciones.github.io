<div id="vision-model" class="fixed inset-0 -z-10 pointer-events-none"></div>

<script>
    import * as THREE from "three";
    import { createGlassCube } from "@/utils/createGlassCube";
    import landingIcon from "@/assets/icons/landing-icon.svg?raw";
    import softwareIcon from "@/assets/icons/software-icon.svg?raw";
    import integrationIcon from "@/assets/icons/integration-icon.svg?raw";

    const container = document.getElementById("vision-model");
    const width = container?.clientWidth || window.innerWidth;
    const height = container?.clientHeight || window.innerHeight;
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(75, width / height, 1, 1000);
    const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
    const dirLight = new THREE.DirectionalLight(0xffffff, 1.2);
    const ambientLight = new THREE.AmbientLight(0xffffff, 0.6);
    const raycaster = new THREE.Raycaster();
    const mouseNDC = new THREE.Vector2();
    const elements = document.querySelectorAll("[data-animation]");
    const customs: Record<string, { svg: string; onClick: () => void }> = {
        "18": {
            svg: softwareIcon.replaceAll('stroke="#000"', 'stroke="#fff"'),
            onClick: () => {
                window.location.href = "#landings";
            },
        },
        "12": {
            svg: landingIcon.replaceAll('stroke="#000"', 'stroke="#fff"'),
            onClick: () => {
                window.location.href = "#software";
            },
        },
        "6": {
            svg: integrationIcon.replaceAll('stroke="#000"', 'stroke="#fff"'),
            onClick: () => {
                window.location.href = "#integrations";
            },
        },
    };

    camera.position.set(0, 3, 8);
    renderer.setSize(width, height);
    renderer.setPixelRatio(window.devicePixelRatio);
    container?.appendChild(renderer.domElement);
    dirLight.position.set(5, 10, 5);
    dirLight.castShadow = true;
    scene.add(ambientLight);
    scene.add(dirLight);

    const group = new THREE.Group();
    const foregroundGroup = new THREE.Group();

    scene.add(group);
    scene.add(foregroundGroup);

    const limit = 5;
    const count = limit * limit;
    const spacing = 1;
    let positionY = 0;
    let positionX = 0;

    for (let i = 0; i < count; i++) {
        if (i % limit === 0) {
            positionY += spacing;
            positionX = 0;
        }

        const cube = createGlassCube({
            position: { x: positionX * spacing, y: positionY, z: 0 },
            size: { x: spacing, y: spacing, z: spacing },
            radius: 0.15,
            svg: (customs[`${i}`]?.svg as any) || null,
            onClick: (customs[`${i}`]?.onClick as any) || null,
        });

        positionX++;
        cube.userData.basePosition = cube.position.clone();
        group.add(cube);
    }

    group.rotation.set(
        THREE.MathUtils.degToRad(-5),
        0,
        THREE.MathUtils.degToRad(45),
    );
    group.position.set(5.5, 2, 0);

    const mouse = { x: 0, y: 0 };
    const targetRotation = { x: 0, y: 0 };
    const slower = 0.02;
    let activeSection = "home";
    let focusCube = null;

    const baseRotation = {
        x: THREE.MathUtils.degToRad(-60),
        y: 0,
        z: THREE.MathUtils.degToRad(90),
    };

    window.addEventListener("mousemove", (e) => {
        mouse.x = (e.clientX / window.innerWidth) * 2 - 1;
        mouse.y = -(e.clientY / window.innerHeight) * 2 + 1;

        mouseNDC.x = mouse.x;
        mouseNDC.y = mouse.y;
    });

    window.addEventListener("scroll", () => {
        const scrollY = window.scrollY;

        for (const element of elements) {
            const auxElement = element as any;
            const start = auxElement?.offsetTop;
            const end = start + auxElement?.offsetHeight;

            if (scrollY >= start && scrollY < end) {
                activeSection = auxElement?.dataset?.animation;
                break;
            }
        }
    });

    window.addEventListener("resize", () => {
        const w = container?.clientWidth || window.innerWidth;
        const h = container?.clientHeight || window.innerHeight;
        camera.aspect = w / h;
        camera.updateProjectionMatrix();
        renderer.setSize(w, h);
    });

    window.addEventListener("click", (e) => {
        mouseNDC.x = (e.clientX / window.innerWidth) * 2 - 1;
        mouseNDC.y = -(e.clientY / window.innerHeight) * 2 + 1;

        raycaster.setFromCamera(mouseNDC, camera);

        const intersects = raycaster.intersectObjects(scene.children, true);

        if (!intersects.length) return;

        for (const hit of intersects) {
            const obj = hit.object;

            if (obj.userData?.onClick) {
                obj.userData.onClick(obj);
                break;
            }

            if (obj.parent?.userData?.onClick) {
                obj.parent.userData.onClick(obj.parent);
                break;
            }
        }
    });

    const animate = () => {
        requestAnimationFrame(animate);

        targetRotation.y = baseRotation.y + mouse.x * 0.05;
        group.rotation.y = THREE.MathUtils.lerp(
            group.rotation.y,
            targetRotation.y,
            0.05,
        );

        raycaster.setFromCamera(mouseNDC, camera);
        const intersects = raycaster.intersectObjects(group.children);

        group.children.forEach((cube) => {
            cube.position.lerp(cube.userData.basePosition, slower);
        });

        if (intersects.length > 0) {
            let hovered = intersects[0].object;

            if (hovered.parent && hovered.parent.userData.basePosition) {
                hovered = hovered.parent;
            }

            hovered.position.lerp(
                hovered.userData.basePosition
                    .clone()
                    .add(new THREE.Vector3(0, 0, 1)),
                0.15,
            );
        }

        if (activeSection === "home") {
            group.position.lerp(new THREE.Vector3(5.5, 0, 0), slower);
        }

        if (activeSection === "landings") {
            group.position.lerp(new THREE.Vector3(5.5, 0, 0), slower);
            group.rotation.y = THREE.MathUtils.lerp(group.rotation.y, 0, 0.08);
            focusCube = group.children[18];
            focusCube.position.lerp(new THREE.Vector3(-3.8, 5, 10), slower);
        }

        if (activeSection === "software") {
            group.position.lerp(new THREE.Vector3(-4, 0, 0), slower);
            group.rotation.y = THREE.MathUtils.lerp(group.rotation.y, 0, 0.08);
            focusCube = group.children[12];
            focusCube.position.lerp(new THREE.Vector3(4.8, -1.8, 10), slower);
        }

        if (activeSection === "integrations") {
            group.position.lerp(new THREE.Vector3(5.5, 0, 0), slower);
            group.rotation.y = THREE.MathUtils.lerp(group.rotation.y, 0, 0.08);
            focusCube = group.children[6];
            focusCube.position.lerp(new THREE.Vector3(-2, 7, 10), slower);
        }

        if (activeSection === "footer") {
            group.position.lerp(new THREE.Vector3(0.5, -4, 0), slower);
        }

        renderer.render(scene, camera);
    };

    animate();
</script>
