---
interface Props {
    image?: string;
    title?: string;
    type?: string;
}

const { 
    image = "",
    title = "",
    type = ""
} = Astro.props;
---

<div class="relative w-full max-w-5xl mx-auto">
    <div class="relative rounded-3xl overflow-hidden h-[420px] group border border-stone-800 backdrop-blur-md backdrop-saturate-150">
        <!-- <div class="absolute top-0 right-0 w-full h-100 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/2 blur-3xl"/> -->
        <div class="absolute inset-0 bg-gradient-to-b via-black/60 bg-white/5"/>
        <img
            src={image}
            alt={title}
            class="absolute inset-0 w-full h-full object-cover"
        />

        <!-- <div class="absolute top-5 left-5">
            <span class="text-xs bg-white/20 backdrop-blur px-3 py-1 rounded-full text-white">
                VR
            </span>
        </div> -->

        <div class="absolute top-5 right-5">
            <button class="text-xs bg-white text-black px-4 py-1 rounded-full font-medium hover:scale-105 transition">
                {type}
            </button>
        </div>

        <div class="relative z-10 flex flex-col items-center justify-center h-full text-center px-6">
            <h4 class="text-4xl md:text-5xl font-bold text-white tracking-tight">
                {title}
            </h4>
            <!-- <span class="mt-6 text-xs bg-white/20 backdrop-blur px-4 py-2 rounded-full text-white">
                Coming Soon
            </span> -->
        </div>
    </div>
</div>
