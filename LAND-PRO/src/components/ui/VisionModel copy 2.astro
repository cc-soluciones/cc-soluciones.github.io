        );

        // UI
        const face = new THREE.Mesh(
            new THREE.PlaneGeometry(2.6, 1.2),
            new THREE.MeshBasicMaterial({
                map: createCardTexture(node),
                transparent: true,
            })
        );
        face.position.z = 0.11;

        group.add(body, face);
        group.position.copy(node.position);

        return group;
    };

