    };

    camera.position.set(0, 0, 8);
    renderer.setSize(width, height);
    renderer.setPixelRatio(window.devicePixelRatio);
    container?.appendChild(renderer.domElement);
    dirLight.position.set(5, 10, 5);
    scene.add(new THREE.AmbientLight(0xffffff, 1));
    scene.add(dirLight);

    const layout = (nodes: any) => {
        const levelMap: any = {};

        nodes.forEach((n: any) => {
            levelMap[n.level] ??= [];
            levelMap[n.level].push(n);
        });

        Object.entries(levelMap).forEach(([level, items]: any) => {
            const offset = (items.length - 1) / 2;

            items.forEach((node: any, i: any) => {
                node.position = new THREE.Vector3(
                    (i - offset) * 3,
                    -level * 1.8,
                    -level * 0.3
                );
            });
        });
    };

    const createCard = (node: any) => {
        const group = new THREE.Group();

        // cuerpo
        const body = new THREE.Mesh(
            new RoundedBoxGeometry(2.8, 1.4, 0.18, 6, 0.15),
