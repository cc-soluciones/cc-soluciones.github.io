---
import Nav from "@/components/ui/Nav.astro";
import Footer from "@/components/ui/Footer.astro";
import { siteConfig } from "@/data/site";
import "@/styles/global.css";
---

<!doctype html>
<html lang="en" class="scroll-smooth">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <meta name="description" content={siteConfig.description}>
        <title>{siteConfig.company}</title>
    </head>
    <body class="bg-primary text-foreground">
        <div id="custom-cursor" class="md:visible invisible">
            <div class="cursor-fill"/>
            <div class="cursor-ring"/>
        </div>
        <Nav/>
        <main class="flex flex-wrap justify-center mx-auto">
            <slot />
        </main>
        <Footer/>
        <script>
            import "@/scripts/cursor";
            import "@/scripts/scrollReveal";
            import "@/scripts/scrollspy";
            import "@/scripts/mobileMenu";
        </script>
    </body>
</html>
