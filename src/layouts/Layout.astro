---
import Nav from "@/components/ui/Nav.astro";
import Footer from "@/components/ui/Footer.astro";
import GridBackground from "@/components/ui/GridBackground.astro";
import { siteConfig } from "@/data/site";
import "@/styles/global.css";
---

<!doctype html>
<html lang="es" class="scroll-smooth dark">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <meta name="description" content={siteConfig.description} />
        <title>{siteConfig.company}</title>

        <meta property="og:type" content="website" />
        <meta property="og:title" content={siteConfig.company} />
        <meta property="og:description" content={siteConfig.description} />
        <meta property="og:url" content={Astro.url} />
        <meta property="og:locale" content="es_CL" />

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={siteConfig.company} />
        <meta name="twitter:description" content={siteConfig.description} />

        <link rel="canonical" href={Astro.url} />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    </head>
    <body class="bg-background text-foreground w-full relative">
        <GridBackground className="-z-100" />
        <Nav/>
        <main>
            <slot />
        </main>
        <Footer/>
        <script>
            import "@/scripts/scrollReveal";
            import "@/scripts/scrollspy";
            import "@/scripts/mobileMenu";
            import "@/lib/typewriter";

            const init = () => {
                const section = document.getElementById("services");
                if (section) {
                    const details = section.querySelectorAll("details");
                    details.forEach((d) => {
                        const summary = d.querySelector("summary");
                        if (!summary) return;
                        summary.addEventListener("click", () => {
                            if (!d.open) {
                                details.forEach((other) => {
                                    if (other !== d) other.open = false;
                                });
                            }
                        });
                    });
                }
            };

            init();

        </script>
    </body>
</html>
