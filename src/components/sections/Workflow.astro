---
import { Icon } from "astro-icon/components";
import { t } from "@/lib/i18n";
import type { Lang } from "@/data/i18n";
import SectionWrapper from "@/components/ui/SectionWrapper.astro";
import SectionHeader from "@/components/ui/SectionHeader.astro";

interface Props {
    lang: Lang;
}

const { lang } = Astro.props;

const steps = [
    { icon: "mdi:clipboard-text-outline", key: "workflow.step1" },
    { icon: "mdi:draw", key: "workflow.step2" },
    { icon: "mdi:code-tags", key: "workflow.step3" },
    { icon: "mdi:rocket-launch", key: "workflow.step4" },
];
---

<SectionWrapper id="workflow" blobs={["bl"]}>
    <SectionHeader
        badge={t(lang, "workflow.badge")}
        title={t(lang, "workflow.title")}
        highlight={t(lang, "workflow.titleHighlight")}
        description={t(lang, "workflow.description")}
        gradient="primary-accent"
    />

    <div class="relative grid grid-cols-1 md:grid-cols-4 gap-8">
        <div class="hidden md:block absolute top-12 left-[12.5%] right-[12.5%] h-0.5 bg-gradient-to-r from-primary via-secondary to-accent opacity-20" />

        {steps.map((step, i) => (
            <div class="relative flex flex-col items-center text-center group">
                <div class="relative w-16 h-16 rounded-2xl bg-gradient-to-br from-white/[0.08] to-white/[0.03] border border-white/[0.08] backdrop-blur-xl flex items-center justify-center mb-5 group-hover:scale-110 group-hover:border-primary/30 transition-all duration-500 z-10">
                    <Icon name={step.icon} class="w-7 h-7 text-primary" />
                </div>

                <span class="text-xs font-semibold tracking-widest text-primary/60 uppercase mb-2">
                    {`0${i + 1}`}
                </span>

                <h3 class="text-base font-semibold text-foreground mb-2">
                    {t(lang, `${step.key}.title`)}
                </h3>

                <p class="text-sm text-foreground-secondary leading-relaxed max-w-xs">
                    {t(lang, `${step.key}.desc`)}
                </p>
            </div>
        ))}
    </div>
</SectionWrapper>
