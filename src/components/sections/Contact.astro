---
import { Icon } from "astro-icon/components";
import { t } from "@/lib/i18n";
import type { Lang } from "@/data/i18n";
import { contactInfo, contactFeatures } from "@/data/contact";
import SectionWrapper from "@/components/ui/SectionWrapper.astro";
import SectionHeader from "@/components/ui/SectionHeader.astro";
import GlassCard from "@/components/ui/GlassCard.astro";
import IconBox from "@/components/ui/IconBox.astro";
import Button from "@/components/ui/Button.astro";

interface Props {
    lang: Lang;
}

const { lang } = Astro.props;
---

<SectionWrapper blobs={["br", "tl"]}>
    <SectionHeader
        badge={t(lang, "contact.badge")}
        title={t(lang, "contact.title")}
        highlight={t(lang, "contact.titleHighlight")}
        description={t(lang, "contact.description")}
        gradient="accent-primary-secondary"
    />

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 max-w-5xl mx-auto">
        <div class="lg:col-span-2 space-y-6">
            {contactFeatures.map((feature) => (
                <GlassCard tag="div" padding="sm" class="flex items-center gap-4 !p-4">
                    <div class="flex items-center gap-4 w-full">
                        <IconBox icon={feature.icon} size="sm" />
                        <div>
                            <h4 class="text-sm font-semibold text-foreground">{feature.title}</h4>
                            <p class="text-xs text-foreground-secondary">{feature.description}</p>
                        </div>
                    </div>
                </GlassCard>
            ))}

            <div class="space-y-3 pt-2">
                <Button href={contactInfo.whatsappLink} variant="whatsapp" icon="mdi:whatsapp" iconPosition="left" rightIcon="mdi:arrow-right">
                    {t(lang, "contact.whatsapp")}
                </Button>
                <Button href={`mailto:${contactInfo.email}`} variant="email" icon="mdi:email" iconPosition="left" rightIcon="mdi:arrow-right">
                    {t(lang, "contact.email")}
                </Button>
            </div>
        </div>

        <div class="lg:col-span-3">
            <GlassCard padding="lg">
                <form id="contact-form" action="https://formsubmit.co/ccsolucionesspa@gmail.com" method="POST">
                    <input type="hidden" name="_subject" value="Nuevo contacto desde landing page" />
                    <input type="hidden" name="_template" value="table" />
                    <input type="hidden" name="_captcha" value="false" />

                    <div class="space-y-4">
                        <div>
                            <label for="name" class="block text-sm font-medium text-foreground mb-1.5">{t(lang, "contact.form.name")}</label>
                            <input type="text" id="name" name="name" required
                                class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-foreground placeholder:text-foreground-secondary/40 text-sm focus:outline-none focus:border-primary/40 focus:ring-1 focus:ring-primary/20 transition-all duration-200"
                                placeholder={t(lang, "contact.form.name")} />
                        </div>
                        <div>
                            <label for="email" class="block text-sm font-medium text-foreground mb-1.5">{t(lang, "contact.form.email")}</label>
                            <input type="email" id="email" name="email" required
                                class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-foreground placeholder:text-foreground-secondary/40 text-sm focus:outline-none focus:border-primary/40 focus:ring-1 focus:ring-primary/20 transition-all duration-200"
                                placeholder={t(lang, "contact.form.email")} />
                        </div>
                        <div>
                            <label for="phone" class="block text-sm font-medium text-foreground mb-1.5">{t(lang, "contact.form.phone")}</label>
                            <input type="tel" id="phone" name="phone"
                                class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-foreground placeholder:text-foreground-secondary/40 text-sm focus:outline-none focus:border-primary/40 focus:ring-1 focus:ring-primary/20 transition-all duration-200"
                                placeholder={t(lang, "contact.form.phone")} />
                        </div>
                        <div>
                            <label for="message" class="block text-sm font-medium text-foreground mb-1.5">{t(lang, "contact.form.message")}</label>
                            <textarea id="message" name="message" required rows="4"
                                class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-foreground placeholder:text-foreground-secondary/40 text-sm focus:outline-none focus:border-primary/40 focus:ring-1 focus:ring-primary/20 transition-all duration-200 resize-none"
                                placeholder={t(lang, "contact.form.message")} />
                        </div>

                        <Button type="submit" variant="primary" size="md" class="w-full justify-center">
                            {t(lang, "contact.form.submit")}
                        </Button>

                        <p class="text-xs text-center text-foreground-secondary/60">
                            {t(lang, "contact.form.responseTime")}
                        </p>
                    </div>
                </form>
            </GlassCard>
        </div>
    </div>
</SectionWrapper>
