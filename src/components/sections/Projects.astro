---
import { Icon } from "astro-icon/components";
import { t } from "@/lib/i18n";
import type { Lang } from "@/data/i18n";
import { projects } from "@/data/projects";
import SectionWrapper from "@/components/ui/SectionWrapper.astro";
import SectionHeader from "@/components/ui/SectionHeader.astro";
import GlassCard from "@/components/ui/GlassCard.astro";

interface Props {
    lang: Lang;
}

const { lang } = Astro.props;
---

<SectionWrapper id="projects" blobs={["tr", "bl"]}>
    <SectionHeader
        badge={t(lang, "projects.badge")}
        title={t(lang, "projects.title")}
        highlight={t(lang, "projects.titleHighlight")}
        description={t(lang, "projects.description")}
        gradient="accent-primary-secondary"
    />

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {projects.map((project) => (
            <GlassCard tag="a" href={project.url} target="_blank" rel="noopener noreferrer" padding="sm" hover={true}>
                <div class="relative aspect-[4/3] -mx-5 -mt-5 mb-5 overflow-hidden rounded-t-3xl">
                    <div class="absolute inset-0 bg-gradient-to-t from-background via-background/20 to-transparent z-10 opacity-60" />
                    {project.images[0] && (
                        <img
                            src={project.images[0].src}
                            alt={project.title}
                            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                            style={{ objectPosition: project.images[0].position }}
                            loading="lazy"
                        />
                    )}
                    <div class="absolute top-3 right-3 z-20">
                        <span class="px-2.5 py-1 text-[10px] font-semibold uppercase tracking-wider rounded-full bg-white/10 backdrop-blur-xl border border-white/10 text-foreground-secondary">
                            {project.type}
                        </span>
                    </div>
                </div>

                <h3 class="text-base font-semibold text-foreground mb-2 group-hover:text-primary transition-colors duration-200 capitalize">
                    {project.title}
                </h3>
                {project.description && (
                    <p class="text-sm text-foreground-secondary leading-relaxed line-clamp-2">
                        {project.description}
                    </p>
                )}
                <div class="flex items-center gap-1.5 mt-3 text-xs font-medium text-primary group-hover:gap-2.5 transition-all duration-300">
                    <span>{t(lang, "projects.viewProject")}</span>
                    <Icon name="mdi:arrow-right" class="w-3.5 h-3.5" />
                </div>
            </GlassCard>
        ))}
    </div>
</SectionWrapper>
