---
import ScaleIn from "@astroanimate/core/ScaleIn";

import Badge from "@/components/ui/Badge.astro";
import Button from "@/components/ui/Button.astro";
import Card from "@/components/ui/Card.astro";
import Title from "@/components/ui/Title.astro";
import Text from "@/components/ui/Text.astro";
import Section from "@/components/ui/Section.astro";

import { Icon } from "astro-icon/components";
import { projects } from "@/data/projects";
import type { Lang } from "@/data/i18n";
import { siteConfig } from "@/data/site";
import { t } from "@/lib/i18n";

const currentLang: Lang = "es";
const sectionId: string = "home";
const orbitItems = [
    { icon: "mdi:calendar", label: "Planning" },
    { icon: "mdi:file-text", label: "Design" },
    { icon: "mdi:code-tags", label: "Development" },
    { icon: "mdi:account", label: "Testing" },
    { icon: "mdi:clock-outline", label: "Release" },
];
---

<Section id={sectionId}>
    <ScaleIn enhance={true}>
        <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-8 items-start">
            <div class="lg:col-span-7 flex flex-col space-y-8 m-auto">
                <div class="flex">
                    <Badge icon="mdi:lightning-bolt">
                        {t(currentLang, "hero.badge")}
                    </Badge>
                </div>
    
                <Title as="h1">
                    {t(currentLang, "hero.title")}
                    <br />
                    {t(currentLang, "hero.titleHighlight")}
                </Title>
    
                <Text size="lg">
                    {t(currentLang, "hero.description")}
                </Text>
                <div class="flex flex-wrap gap-4 flex-col md:flex-row">
                    <Button
                        href="https://wa.me/56927240093"
                        variant="primary"
                        size="lg"
                        icon="mdi:whatsapp"
                    >
                        {t(currentLang, "hero.cta")}
                    </Button>
                    <Button
                        href="#projects"
                        variant="outline"
                        size="lg"
                        icon="mdi:arrow-right"
                    >
                        {t(currentLang, "hero.ctaSecondary")}
                    </Button>
                </div>
            </div>
    
            <div class="lg:col-span-5  lg:mt-12">
                <div class="hidden md:flex relative w-full h-100 sm:h-125 items-center justify-center">
                    <div class="absolute rounded-full bg-linear-to-br flex items-center justify-center z-10">
                        <div class="absolute w-34 h-34 rounded-full border animate-ping opacity-50" style="animation-delay: 0.5s"/>
                         <img
                            src={siteConfig.logo}
                            alt={siteConfig.company}
                            class="h-35 w-50"
                        />
                    </div>
    
                    <div class="absolute w-96 h-96 rounded-full border border-border"></div>
    
                    {orbitItems.map((item, i) => {
                        const angle = (i / orbitItems.length) * 360;
                        const radius = 190;
                        const x = Math.cos((angle * Math.PI) / 170) * radius;
                        const y = Math.sin((angle * Math.PI) / 170) * radius;
                        return (
                            <div
                                class="absolute"
                                style={`
                                    transform: translate(${x}px, ${y}px);
                                `}
                            >
                                <div
                                    class="absolute rounded-full -inset-1"
                                    style={`
                                        background: radial-gradient(circle, rgba(255,255,255,0.2) 0%, rgba(255,255,255,0) 70%);
                                        width: ${70 + i * 5}px;
                                        height: ${70 + i * 5}px;
                                        left: -${15 + i * 2.5}px;
                                        top: -${15 + i * 2.5}px;
                                    `}
                                />
                                <div class="w-10 h-10 rounded-full flex items-center justify-center border-2 border-border bg-foreground/5 backdrop-blur-sm">
                                    <Icon
                                        name={item.icon}
                                        class="w-5 h-5 text-foreground/80"
                                    />
                                </div>
                                <div class="absolute top-12 left-1/2 -translate-x-1/2 whitespace-nowrap text-xs font-semibold tracking-wider transition-all duration-300 text-foreground/70">
                                    {item.label}
                                </div>
                            </div>
                        );
                    })}
                </div>
                <Card>
                    <Title as="h3" class="text-sm! text-foreground/60">
                        {t(currentLang, "hero.marquee.title")}
                    </Title>
                    <div class="relative flex overflow-hidden pt-5">
                        <div class="animate-marquee flex gap-12 whitespace-nowrap px-4">
                            {[...projects, ...projects].map((p) => (
                                <a
                                    href={p.url}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="flex items-center gap-2 opacity-50 transition-all hover:opacity-100 hover:scale-105 cursor-pointer grayscale hover:grayscale-0"
                                >
                                    <Icon
                                        name="mdi:hexagon"
                                        class="h-5 w-5 text-foreground/70"
                                    />
                                    <Text class="font-bold text-foreground">
                                        {p.title}
                                    </Text>
                                </a>
                            ))}
                        </div>
                    </div>
                </Card>
            </div>
        </div>
    </ScaleIn>
</Section>

<style is:global>
    @keyframes marquee {
        from {
            transform: translateX(0);
        }
        to {
            transform: translateX(-50%);
        }
    }
</style>