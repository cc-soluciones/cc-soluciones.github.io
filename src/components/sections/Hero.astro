---
import { Icon } from "astro-icon/components";
import { t } from "@/lib/i18n";
import type { Lang } from "@/data/i18n";
import Button from "@/components/ui/Button.astro";
import GlassCard from "@/components/ui/GlassCard.astro";
import Badge from "@/components/ui/Badge.astro";
import IconBox from "@/components/ui/IconBox.astro";

interface Props {
    lang: Lang;
}

const { lang } = Astro.props;

const brands = [
    { icon: "mdi:hexagon", name: "Blacker" },
    { icon: "mdi:triangle", name: "La Pily" },
    { icon: "mdi:apple-keyboard-command", name: "Denaval" },
    { icon: "mdi:ghost", name: "Pingüino" },
    { icon: "mdi:diamond-stone", name: "E. Power" },
    { icon: "mdi:chip", name: "Maquental" },
];

const duplicatedBrands = [...brands, ...brands];
---

<section id="home" class="relative min-h-screen flex items-center overflow-hidden bg-background">
    <div
        class="absolute inset-0 z-0 bg-[url('/hero-bg.svg')] bg-repeat opacity-40 dark:opacity-30"
        style="mask-image: linear-gradient(transparent, black 0%, black 70%, transparent); -webkit-mask-image: linear-gradient(transparent, black 0%, black 70%, transparent); background-size: 200px 200px;"
    />

    <div class="absolute inset-0 z-[1] pointer-events-none">
        <div class="absolute top-1/4 -left-32 w-[500px] h-[500px] rounded-full bg-gradient-to-r from-primary/15 via-secondary/10 to-transparent blur-[120px]" />
        <div class="absolute bottom-1/4 -right-32 w-[400px] h-[400px] rounded-full bg-gradient-to-l from-accent/10 via-primary/5 to-transparent blur-[100px]" />
    </div>

    <div class="relative z-10 mx-auto max-w-7xl px-4 pt-24 pb-12 sm:px-6 md:pt-32 md:pb-20 lg:px-8 w-full">
        <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-8 items-start">
            <div class="lg:col-span-7 flex flex-col justify-center space-y-8 pt-8">
                <div class="animate-fade-in delay-100">
                    <Badge icon="mdi:star" iconClass="text-accent">
                        {t(lang, "hero.badge")}
                    </Badge>
                </div>

                <h1
                    class="animate-fade-in delay-200 text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-semibold tracking-tighter leading-[0.9]"
                    style="mask-image: linear-gradient(black 0%, black 80%, transparent 100%); -webkit-mask-image: linear-gradient(black 0%, black 80%, transparent 100%);"
                >
                    {t(lang, "hero.title")}<br />
                    <span class="bg-gradient-to-br from-foreground via-foreground to-accent bg-clip-text text-transparent">
                        {t(lang, "hero.titleHighlight")}
                    </span>
                </h1>

                <p class="animate-fade-in delay-300 max-w-xl text-base sm:text-lg text-foreground-secondary leading-relaxed">
                    {t(lang, "hero.description")}
                </p>

                <div class="animate-fade-in delay-400 flex flex-col sm:flex-row gap-4">
                    <Button href="#contact" variant="primary" size="md" icon="mdi:arrow-right">
                        {t(lang, "hero.cta")}
                    </Button>
                    <Button href="#projects" variant="secondary" size="md" icon="mdi:play" iconPosition="left">
                        {t(lang, "hero.ctaSecondary")}
                    </Button>
                </div>
            </div>

            <div class="lg:col-span-5 space-y-6 lg:mt-12">
                <GlassCard padding="md" class="animate-fade-in delay-500">
                    <div class="flex items-center gap-4 mb-8">
                        <IconBox icon="mdi:target" size="md" />
                        <div>
                            <div class="text-3xl font-bold tracking-tight text-foreground">50+</div>
                            <div class="text-sm text-foreground-secondary">{t(lang, "hero.stats.projects")}</div>
                        </div>
                    </div>

                    <div class="space-y-3 mb-8">
                        <div class="flex justify-between text-sm">
                            <span class="text-foreground-secondary">{t(lang, "hero.stats.satisfaction")}</span>
                            <span class="text-foreground font-medium">98%</span>
                        </div>
                        <div class="h-2 w-full overflow-hidden rounded-full bg-muted">
                            <div class="h-full w-[98%] rounded-full bg-gradient-to-r from-primary to-secondary" />
                        </div>
                    </div>

                    <div class="h-px w-full bg-white/10 mb-6" />

                    <div class="flex justify-center text-center">
                        <div class="flex flex-col items-center justify-center transition-transform hover:-translate-y-1 cursor-default flex-1">
                            <span class="text-xl font-bold text-foreground sm:text-2xl">5+</span>
                            <span class="text-[10px] uppercase tracking-wider text-foreground-secondary/60 font-medium sm:text-xs">{t(lang, "hero.stats.years")}</span>
                        </div>
                        <div class="w-px bg-white/10 my-2" />
                        <div class="flex flex-col items-center justify-center transition-transform hover:-translate-y-1 cursor-default flex-1">
                            <span class="text-xl font-bold text-foreground sm:text-2xl">24/7</span>
                            <span class="text-[10px] uppercase tracking-wider text-foreground-secondary/60 font-medium sm:text-xs">{t(lang, "hero.stats.support")}</span>
                        </div>
                        <div class="w-px bg-white/10 my-2" />
                        <div class="flex flex-col items-center justify-center transition-transform hover:-translate-y-1 cursor-default flex-1">
                            <span class="text-xl font-bold text-foreground sm:text-2xl">100%</span>
                            <span class="text-[10px] uppercase tracking-wider text-foreground-secondary/60 font-medium sm:text-xs">{t(lang, "hero.stats.quality")}</span>
                        </div>
                    </div>

                    <div class="mt-8 flex flex-wrap gap-2">
                        <Badge dot="green">ACTIVO</Badge>
                        <Badge icon="mdi:crown" iconClass="text-accent">PREMIUM</Badge>
                    </div>
                </GlassCard>

                <GlassCard padding="sm" class="animate-fade-in delay-500">
                    <h3 class="mb-4 text-sm font-medium text-foreground-secondary">
                        {t(lang, "hero.marquee.title")}
                    </h3>
                    <div class="relative flex overflow-hidden" style="mask-image: linear-gradient(to right, transparent, black 20%, black 80%, transparent); -webkit-mask-image: linear-gradient(to right, transparent, black 20%, black 80%, transparent);">
                        <div class="animate-marquee flex gap-12 whitespace-nowrap">
                            {duplicatedBrands.map((item) => (
                                <div class="flex items-center gap-2 opacity-50 transition-all hover:opacity-100 hover:scale-105 cursor-default grayscale hover:grayscale-0">
                                    <Icon name={item.icon} class="h-5 w-5 text-foreground" aria-hidden="true" />
                                    <span class="text-sm font-bold text-foreground tracking-tight">{item.name}</span>
                                </div>
                            ))}
                        </div>
                    </div>
                </GlassCard>
            </div>
        </div>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 animate-bounce">
        <Icon name="mdi:chevron-double-down" class="w-5 h-5 text-foreground-secondary/50" aria-hidden="true" />
    </div>
</section>
