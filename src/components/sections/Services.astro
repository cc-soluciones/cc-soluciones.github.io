---
import { t } from "@/lib/i18n";
import type { Lang } from "@/data/i18n";
import SectionWrapper from "@/components/ui/SectionWrapper.astro";
import SectionHeader from "@/components/ui/SectionHeader.astro";
import GlassCard from "@/components/ui/GlassCard.astro";
import IconBox from "@/components/ui/IconBox.astro";

interface Props {
    lang: Lang;
}

const { lang } = Astro.props;

const serviceKeys = [
    { icon: "mdi:layers", title: "services.item0.title", descs: ["services.item0.desc0", "services.item0.desc1"] },
    { icon: "mdi:code-tags", title: "services.item1.title", descs: ["services.item1.desc0", "services.item1.desc1"] },
    { icon: "mdi:connection", title: "services.item2.title", descs: ["services.item2.desc0", "services.item2.desc1"] },
];
---

<SectionWrapper id="services" blobs={["tr"]}>
    <SectionHeader
        badge={t(lang, "services.badge")}
        title={t(lang, "services.title")}
        highlight={t(lang, "services.titleHighlight")}
        description={t(lang, "services.description")}
        gradient="primary-secondary"
    />

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {serviceKeys.map((service) => (
            <GlassCard tag="article" padding="lg" hover={true}>
                <IconBox icon={service.icon} size="md" class="mb-5" />
                <h3 class="text-lg font-semibold text-foreground mb-3">
                    {t(lang, service.title)}
                </h3>
                <div class="space-y-2">
                    {service.descs.map((desc) => (
                        <p class="text-sm text-foreground-secondary leading-relaxed">
                            {t(lang, desc)}
                        </p>
                    ))}
                </div>
            </GlassCard>
        ))}
    </div>
</SectionWrapper>
