---
import SectionHeader from "@/components/ui/SectionHeader.astro";
import CardServices from "@/components/ui/CardServices.astro";
import { services } from "@/data/services";

interface Props {
    id?: string;
}

const { id = "services" } = Astro.props as Props;
---

<section id={id} class="max-w-7xl mx-auto px-6 py-32" data-animation="services">
    <SectionHeader
        badge="Servicios"
        title="Lo que"
        highlight="hacemos"
        description="Desarrollamos soluciones digitales con proceso claro, entregas por hitos y acompañamiento técnico continuo."
    />
    <div class="flex flex-wrap md:flex-nowrap gap-4 justify-center">
        {
            services && Object.values(services).map((item, index) => (
                <CardServices
                    title={item.label}
                    descriptions={item.descriptions}
                    index={index}
                    open={index === 0}
                />
            ))
        }
    </div>
</section>
