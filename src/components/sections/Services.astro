---
import Section from "@/components/ui/Section.astro"
import Title from "@/components/ui/Title.astro"
import Text from "@/components/ui/Text.astro"
import Badge from "@/components/ui/Badge.astro"
import { Icon } from "astro-icon/components"
import { services } from "@/data/services"
import { t } from "@/lib/i18n"
import type { Lang } from "@/data/i18n"

const currentLang: Lang = "es"

const icons: Record<string, string> = {
  "Landing pages": "mdi:web",
  "Software a Medida": "mdi:code-tags",
  Integraciones: "mdi:puzzle",
}
---

<Section id="services">
  <div class="flex flex-col gap-4 mb-12 items-center text-center">
    <Badge icon="mdi:lightning-bolt">
      {t(currentLang, "services.badge")}
    </Badge>
    <Title as="h2" highlight={t(currentLang, "services.titleHighlight")}>
      {t(currentLang, "services.title")}
    </Title>
    <Text size="lg" class="max-w-xl">
      {t(currentLang, "services.description")}
    </Text>
  </div>

  <div class="flex flex-col md:flex-row gap-2 md:gap-4 md:h-[420px]">
    {services.map((svc) => (
      <details
        class="group md:flex-1 transition-all duration-500 ease-in-out overflow-hidden rounded-3xl border border-border bg-white/5 backdrop-blur-sm hover:md:flex-[3] hover:shadow-lg hover:shadow-primary/5"
        onmouseenter="this.setAttribute('open','')"
        onmouseleave="this.removeAttribute('open')"
      >
        <summary class="flex md:flex-col items-center gap-3 md:gap-4 p-5 md:p-6 md:w-20 cursor-pointer list-none select-none hover:bg-white/5 transition-colors [&::-webkit-details-marker]:hidden">
          <div class="w-10 h-10 rounded-xl bg-white/10 flex items-center justify-center shrink-0 transition-colors group-open:bg-primary/20">
            <Icon name={icons[svc.label] || "mdi:code-tags"} class="w-5 h-5 text-foreground/80 group-open:text-primary" />
          </div>
          <span class="text-sm font-semibold tracking-tight whitespace-nowrap md:[writing-mode:vertical-lr] md:[text-orientation:mixed] md:tracking-wider md:uppercase md:text-[10px]">
            {svc.label}
          </span>
        </summary>

        <div class="px-5 pb-6 md:px-6 md:pb-8 md:absolute md:left-24 md:top-0 md:right-0 md:h-full md:flex md:flex-col md:justify-center md:gap-4">
          <Text size="lg" class="font-medium">
            {svc.descriptions[0]}
          </Text>
          <Text>
            {svc.descriptions[1]}
          </Text>
        </div>
      </details>
    ))}
  </div>
</Section>
