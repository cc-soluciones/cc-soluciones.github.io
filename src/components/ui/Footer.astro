---
import SocialIcon from "@/components/ui/SocialIcon.astro";
import { siteConfig, socialsConfig, footerConfig } from "@/data/site";
import { services } from "@/data/services";
---

<footer class="bg-background border-t border-white/5 pt-16">
    <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-16 px-6">
            <div class="md:col-span-2">
                <div class="text-2xl font-black mb-6 tracking-tighter">
                    {siteConfig.company.split(" ")[0]} <span class="text-gradient-secondary">{siteConfig.company.split(" ")[1]}</span>
                </div>
                <p class="text-slate-400 max-w-sm mb-8">
                    {footerConfig.description}
                </p>
                <ul class="flex gap-4">
                    {
                        Object.entries(socialsConfig).map(([key, value]) => (
                            <SocialIcon
                                href={value.href}
                                label={value.label}
                                tooltip={value.tooltip}
                                color={value.color}
                                name={value.icon}
                                social={key}
                            />
                        ))
                    }
                </ul>
            </div>
            <div>
                <h4 class="font-bold mb-6 text-white uppercase tracking-wider text-sm">
                    Servicios
                </h4>
                <ul class="space-y-4">
                    {services && services.map((item, index) => (
                        <li>
                            <a
                                class="text-slate-400 hover:text-white transition-colors"
                                href={item.href}>{item.label}</a
                            >
                        </li>
                    ))}
                </ul>
            </div>
        </div>
        <div class="pt-8 pb-16 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-6 px-6">
                <p class="text-sm text-slate-500">
                    © {new Date().getFullYear()} {siteConfig.company}. Todos los derechos reservados.
                </p>
            <div class="flex gap-8">
                <a
                    class="text-xs text-slate-500 hover:text-white transition-colors"
                    href="#">Política de Privacidad</a
                >
                <a
                    class="text-xs text-slate-500 hover:text-white transition-colors"
                    href="#">Términos de Servicio</a
                >
            </div>
        </div>
    </div>
</footer>
