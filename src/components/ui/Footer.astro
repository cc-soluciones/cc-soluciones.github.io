---
import {
    siteConfig,
    footerConfig,
    socialsConfig,
    type SocialId,
} from "@/data/site";
import { t } from "@/lib/i18n";
import { Icon } from "astro-icon/components";
import type { Lang } from "@/data/i18n";

const currentLang: Lang = "es";
const year = new Date().getFullYear();
const socialIds: SocialId[] = [
    "linkedin",
    "github",
    "instagram",
    "whatsapp",
    "email",
];
---

<footer class="border-t border-border relative bg-background">
    <div class="mx-auto max-w-7xl px-4 py-16 lg:px-12">
        <div class="mb-16 grid grid-cols-2 gap-8 md:grid-cols-4 lg:grid-cols-5">
            <div class="col-span-2 lg:col-span-2">
                <div class="mb-6 flex items-center gap-3">
                    <img
                        src={siteConfig.logo}
                        alt={siteConfig.company}
                        class="h-8 w-auto"
                    />
                    <span class="text-lg font-bold tracking-tight">
                        {siteConfig.company}
                    </span>
                </div>
                <p class="text-foreground/60 mb-6 max-w-sm">
                    {footerConfig.description}
                </p>
                <div class="flex gap-3">
                    {socialIds.map((id) => {
                        const social = socialsConfig[id];
                        return (
                            <a
                                href={social.href}
                                target="_blank"
                                rel="noopener noreferrer"
                                aria-label={social.tooltip}
                                title={social.tooltip}
                                class="flex h-10 w-10 items-center justify-center rounded-full border border-border/10 bg-foreground/5 backdrop-blur-sm hover:bg-primary/10 hover:border-primary/30 transition-all"
                            >
                                <Icon
                                    name={social.icon}
                                    class="w-5 h-5 text-foreground/70"
                                />
                            </a>
                        );
                    })}
                </div>
            </div>

            <div>
                <h4 class="mb-4 text-sm font-semibold uppercase tracking-wider text-foreground/80">
                    Recursos
                </h4>
                <ul class="space-y-3">
                    <li>
                        <a href="#projects" class="text-foreground/60 hover:text-foreground transition text-sm">
                            {t(currentLang, "nav.projects")}
                        </a>
                    </li>
                    <li>
                        <a href="#workflow" class="text-foreground/60 hover:text-foreground transition text-sm">
                            {t(currentLang, "nav.workflow")}
                        </a>
                    </li>
                    <li>
                        <a href="#faq" class="text-foreground/60 hover:text-foreground transition text-sm">\
                            {t(currentLang, "nav.faq")}
                        </a>
                    </li>
                </ul>
            </div>
        </div>

        <div class="border-t border-border pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
            <p class="text-foreground/40 text-sm">
                &copy; {year}
                {siteConfig.company}. {t(currentLang, "footer.rights")}
            </p>
            <p class="text-foreground/40 text-sm">
                {t(currentLang, "footer.social")}
            </p>
        </div>
    </div>
</footer>
