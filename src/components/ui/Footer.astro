---
import { Icon } from "astro-icon/components";
import { t } from "@/lib/i18n";
import type { Lang } from "@/data/i18n";
import { siteConfig, socialsConfig } from "@/data/site";
import GlassCard from "@/components/ui/GlassCard.astro";

interface Props {
    lang: Lang;
}

const { lang } = Astro.props;
const year = new Date().getFullYear();
---

<footer id="contact" class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-background via-background to-background/50 pointer-events-none" />

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-16">
            <GlassCard padding="md">
                <div class="flex items-center gap-2.5 mb-4">
                    <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-primary to-secondary flex items-center justify-center text-white font-bold text-sm shadow-lg shadow-primary/20">
                        CC
                    </div>
                    <span class="font-semibold text-foreground text-sm">{siteConfig.company}</span>
                </div>
                <p class="text-sm text-foreground-secondary leading-relaxed max-w-xs">
                    {t(lang, "footer.description")}
                </p>
            </GlassCard>

            <GlassCard padding="md">
                <h3 class="text-sm font-semibold text-foreground uppercase tracking-widest text-xs mb-4">
                    {t(lang, "footer.social")}
                </h3>
                <div class="flex flex-wrap gap-3">
                    {Object.values(socialsConfig).map((social) => (
                        <a href={social.href} target="_blank" rel="noopener noreferrer"
                            class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-foreground-secondary hover:text-foreground hover:border-primary/30 hover:bg-white/10 hover:shadow-lg hover:shadow-primary/10 transition-all duration-300 group"
                            title={social.tooltip}>
                            <Icon name={social.icon} class="w-5 h-5" />
                        </a>
                    ))}
                </div>
            </GlassCard>

            <GlassCard padding="md">
                <h3 class="text-sm font-semibold text-foreground uppercase tracking-widest text-xs mb-4">
                    Contacto
                </h3>
                <div class="space-y-3">
                    <a href="mailto:ccsolucionesspa@gmail.com"
                        class="flex items-center gap-3 text-sm text-foreground-secondary hover:text-primary transition-colors duration-200">
                        <Icon name="mdi:email" class="w-4 h-4 flex-shrink-0" />
                        ccsolucionesspa@gmail.com
                    </a>
                    <a href="https://wa.me/56927240093" target="_blank" rel="noopener noreferrer"
                        class="flex items-center gap-3 text-sm text-foreground-secondary hover:text-primary transition-colors duration-200">
                        <Icon name="mdi:whatsapp" class="w-4 h-4 flex-shrink-0" />
                        +56 9 2724 0093
                    </a>
                </div>
            </GlassCard>
        </div>

        <div class="relative pt-8 border-t border-white/5">
            <p class="text-xs text-foreground-secondary/60 text-center">
                &copy; {year} {siteConfig.company}. {t(lang, "footer.rights")}
            </p>
        </div>
    </div>
</footer>
