---
export interface Props {
    size?: "sm" | "base" | "lg";
    color?: "default" | "muted" | "accent";
    as?: "p" | "span";
}

const { 
    size = "base", 
    color = "muted", 
    as: Tag = "p" 
} = Astro.props as Props;

const sizes = {
    sm: "text-sm",
    base: "text-base",
    lg: "text-base sm:text-lg",
};

const colors = {
    default: "text-foreground",
    muted: "text-foreground/60",
    accent: "text-primary",
};
---

<Tag class={`${sizes[size]} ${colors[color]} leading-relaxed`}>
    <slot />
</Tag>
