---
import Link from "@/components/ui/Link.astro";
import { whatsappLink } from "@/constants/general";

interface Props {
    title?: string;
    descriptions?: string;
    features?: string[];
    direction?: "left" | "right";
    index?: number;
    timeline?: string;
    price?: string;
}

const { 
    title = "",
    descriptions = "",
    features = [],
    direction = "left",
    index = 0,
    timeline = "",
    price = ""
} = Astro.props as Props;

const formattedIndex = String(index + 1).padStart(2, "0");
---

<div
    class:list={[
        "flex flex-col lg:flex-row gap-12 lg:gap-20 items-center mt-10 reveal opacity-0 transition-all duration-700 ease-out",
        direction === "right" && "lg:flex-row-reverse"
    ]}
>
    <div class="lg:w-1/2 space-y-8">
        <div class="flex items-center gap-4">
            <span class="text-6xl md:text-8xl font-black text-white/5 leading-none select-none">
                {formattedIndex}
            </span>
            <div class="h-px flex-1 bg-gradient-to-r from-white/10 to-transparent"/>
        </div>
        
        <div class="space-y-6">
            <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-gradient">
                {title}
            </h2>
            
            <div class="space-y-4">
                {descriptions.split("|").map((item) => (
                    <p class="text-base md:text-lg text-zinc-400 leading-[1.8] font-light">
                        {item}
                    </p>
                ))}
            </div>
            
            {features.length > 0 && (
                <div class="pt-4">
                    <h4 class="text-sm font-semibold uppercase tracking-wider text-white/40 mb-4">
                        Incluye
                    </h4>
                    <ul class="space-y-3">
                        {features.map((feature) => (
                            <li class="flex items-start gap-3 group">
                                <span class="flex-shrink-0 w-5 h-5 rounded-full bg-secondary/10 border border-secondary/20 flex items-center justify-center mt-0.5">
                                    <svg class="w-3 h-3 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                                    </svg>
                                </span>
                                <span class="text-zinc-300 group-hover:text-white transition-colors duration-300">
                                    {feature}
                                </span>
                            </li>
                        ))}
                    </ul>
                </div>
            )}
            
            <div class="flex flex-wrap items-center gap-6 pt-4">
                {timeline && (
                    <div class="flex items-center gap-2 text-sm text-white/50">
                        <svg class="w-4 h-4 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        <span>{timeline}</span>
                    </div>
                )}
                {price && (
                    <div class="flex items-center gap-2 text-sm text-white/50">
                        <svg class="w-4 h-4 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        <span>{price}</span>
                    </div>
                )}
            </div>
            
            <div class="pt-4">
                <Link href={whatsappLink} target="_blank" size="lg">
                    Consultar por este servicio
                </Link>
            </div>
        </div>
    </div>
    
    <div class="lg:w-1/2 md:block hidden">
        <div class="liquid-glass-strong rounded-3xl p-6 md:p-12 relative">
            <div class="absolute top-0 right-0 w-32 h-32 bg-secondary/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"/>
            <div class="absolute bottom-0 left-0 w-24 h-24 bg-white/5 rounded-full blur-2xl translate-y-1/2 -translate-x-1/2"/>
            
            <div class="relative z-10">
                <div class="flex items-center gap-3 mb-8">
                    <div class="w-3 h-3 rounded-full bg-red-400/80"/>
                    <div class="w-3 h-3 rounded-full bg-yellow-400/80"/>
                    <div class="w-3 h-3 rounded-full bg-green-400/80"/>
                    <div class="ml-auto text-xs text-white/30 font-mono">{title.toLowerCase().replace(/\s/g, "-")}.tsx</div>
                </div>
                
                <div class="space-y-4 font-mono text-sm">
                    <div class="flex gap-4">
                        <span class="text-white/20 select-none">1</span>
                        <span class="text-secondary">import</span>
                        <span class="text-white/70">{"{ "}{title}{" }"}</span>
                        <span class="text-secondary">from</span>
                        <span class="text-green-400/70">"@ccsoluciones/services"</span>
                    </div>
                    <div class="flex gap-4">
                        <span class="text-white/20 select-none">2</span>
                        <span class="text-white/30">// Desarrollo profesional garantizado</span>
                    </div>
                    <div class="flex gap-4">
                        <span class="text-white/20 select-none">3</span>
                    </div>
                    <div class="flex gap-4">
                        <span class="text-white/20 select-none">4</span>
                        <span class="text-secondary">const</span>
                        <span class="text-blue-300"> proyecto</span>
                        <span class="text-white/70"> = </span>
                        <span class="text-secondary">new</span>
                        <span class="text-white/70"> Proyecto({"{"}</span>
                    </div>
                    <div class="flex gap-4">
                        <span class="text-white/20 select-none">5</span>
                        <span class="text-white/70 pl-4">calidad:</span>
                        <span class="text-green-400/70">"premium"</span>
                        <span class="text-white/70">,</span>
                    </div>
                    <div class="flex gap-4">
                        <span class="text-white/20 select-none">6</span>
                        <span class="text-white/70 pl-4">entrega:</span>
                        <span class="text-green-400/70">"{timeline || 'por hitos'}"</span>
                        <span class="text-white/70">,</span>
                    </div>
                    <div class="flex gap-4">
                        <span class="text-white/20 select-none">7</span>
                        <span class="text-white/70 pl-4">soporte:</span>
                        <span class="text-green-400/70">"24/7"</span>
                    </div>
                    <div class="flex gap-4">
                        <span class="text-white/20 select-none">8</span>
                        <span class="text-white/70">{"}"})</span>
                    </div>
                    <div class="flex gap-4">
                        <span class="text-white/20 select-none">9</span>
                    </div>
                    <div class="flex gap-4">
                        <span class="text-white/20 select-none">10</span>
                        <span class="text-white/70">proyecto.</span>
                        <span class="text-yellow-300/80">lanzar</span>
                        <span class="text-white/70">()</span>
                        <span class="text-white/30"> // Tu éxito digital comienza aquí</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
