---
interface Props {
    title?: string;
    descriptions?: string;
    direction?: "left" | "right";
}

const { 
    title = "" ,
    descriptions = "",
    direction = "left"
} = Astro.props as Props;

---
<div
    class:list={[
        "flex flex-col lg:flex-row gap-20 items-center mt-10 reveal opacity-0 transition-all duration-700 ease-out",
        direction === "right" && "lg:flex-row-reverse"
    ]}
>
    <div class="service-card py-12 lg:py-16 rounded-[2.5rem] overflow-hidden border border-stone-800 p-12 backdrop-blur-md backdrop-saturate-150 lg:w-1/2">
        <h2 class="text-2xl md:text-5xl font-bold mb-10 tracking-tight">
            {title}
        </h2>

        <div class="space-y-8">
            {descriptions.split("|").map((item) => (
                <p class="text-lg md:text-xl text-zinc-300 leading-[1.8] font-light">
                    {item}
                </p>
            ))}
        </div>
    </div>
</div>
