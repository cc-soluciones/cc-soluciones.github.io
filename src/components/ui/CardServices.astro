---
import Link from "@/components/ui/Link.astro";
import { contactInfo } from "@/data/contact";

interface Props {
    title?: string;
    descriptions?: string[];
    index?: number;
}

const {
    title = "",
    descriptions = [],
    index = 0,
} = Astro.props as Props;

const formattedIndex = String(index + 1).padStart(2, "0");
---

<div class="glass rounded-2xl p-6 md:p-8 flex flex-col gap-4 md:gap-5">
    <div class="flex items-center gap-3">
        <span class="text-2xl md:text-3xl font-black text-white/15 leading-none select-none">
            {formattedIndex}
        </span>
    </div>

    <h3 class="text-xl md:text-2xl font-bold tracking-tight text-gradient">
        {title}
    </h3>

    <div class="space-y-3">
        {
            descriptions.map((item) => (
                <p class="text-sm md:text-base text-zinc-400 leading-relaxed font-light">
                    {item}
                </p>
            ))
        }
    </div>

    <div class="pt-2 mt-auto">
        <Link href={contactInfo.whatsappLink} target="_blank" size="md">
            Consultar
        </Link>
    </div>
</div>
