---
import Link from "@/components/ui/Link.astro";
import { contactInfo } from "@/data/contact";

interface Props {
    title?: string;
    descriptions?: string;
    features?: string[];
    direction?: "left" | "right";
    index?: number;
    timeline?: string;
    price?: string;
}

const {
    title = "",
    descriptions = "",
    features = [],
    direction = "left",
    index = 0,
    timeline = "",
    price = "",
} = Astro.props as Props;

const formattedIndex = String(index + 1).padStart(2, "0");
---

<div
    class:list={[
        "flex flex-col lg:flex-row gap-12 lg:gap-20 items-center mt-10 reveal opacity-0 transition-all duration-700 ease-out border border-white/10 rounded-3xl px-6 md:px-12 bg-gradient-to-tr from-black to-slate-900 h-180",
        "right"
        // direction === "right" && "lg:flex-row-reverse",
    ]}
>
    <div class="lg:w-1/2 space-y-8 py-12">
        <div class="flex items-center gap-4">
            <span
                class="text-4xl md:text-6xl font-black text-white/15 leading-none select-none"
            >
                {formattedIndex}
            </span>
            <div
                class="h-px flex-1 bg-gradient-to-r from-white/10 to-transparent"
            >
            </div>
        </div>

        <div class="space-y-6 flex flex-col justify-center h-120">
            <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-gradient">
                {title}
            </h2>

            <div class="space-y-4">
                {
                    descriptions
                        .split("|")
                        .map((item) => (
                            <p class="text-base md:text-lg text-zinc-400 leading-[1.8] font-light">
                                {item}
                            </p>
                        ))
                }
            </div>

            <!-- {
                features.length > 0 && (
                    <div class="pt-4">
                        <h4 class="text-sm font-semibold uppercase tracking-wider text-white/40 mb-4">
                            Incluye
                        </h4>
                        <ul class="space-y-3">
                            {features.map((feature) => (
                                <li class="flex items-start gap-3 group">
                                    <span class="flex-shrink-0 w-5 h-5 rounded-full bg-secondary/10 border border-secondary/20 flex items-center justify-center mt-0.5">
                                        <svg
                                            class="w-3 h-3 text-secondary"
                                            fill="none"
                                            stroke="currentColor"
                                            viewBox="0 0 24 24"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="3"
                                                d="M5 13l4 4L19 7"
                                            />
                                        </svg>
                                    </span>
                                    <span class="text-zinc-300 group-hover:text-white transition-colors duration-300">
                                        {feature}
                                    </span>
                                </li>
                            ))}
                        </ul>
                    </div>
                )
            } -->

            <div class="flex flex-wrap items-center gap-6 pt-4">
                {
                    timeline && (
                        <div class="flex items-center gap-2 text-sm text-white/50">
                            <svg
                                class="w-4 h-4 text-secondary"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                                />
                            </svg>
                            <span>{timeline}</span>
                        </div>
                    )
                }
                {
                    price && (
                        <div class="flex items-center gap-2 text-sm text-white/50">
                            <svg
                                class="w-4 h-4 text-secondary"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                                />
                            </svg>
                            <span>{price}</span>
                        </div>
                    )
                }
            </div>

            <div class="pt-4">
                <Link href={contactInfo.whatsappLink} target="_blank" size="lg">
                    Consultar por este servicio
                </Link>
            </div>
        </div>
    </div>

    <div class="border-l border-white/10 lg:w-1/2 h-full md:flex hidden items-center justify-center pl-12">
        <div class="liquid-glass-strong rounded-3xl p-6 relative w-full">
            <div class="absolute top-0 right-0 w-32 h-32 bg-secondary/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"/>
            <div class="absolute bottom-0 left-0 w-24 h-24 bg-white/5 rounded-full blur-2xl translate-y-1/2 -translate-x-1/2"/>

            <div class="relative z-10">
                <div class="flex items-center gap-3 mb-8">
                    <div class="w-3 h-3 rounded-full bg-red-400/80"></div>
                    <div class="w-3 h-3 rounded-full bg-yellow-400/80"></div>
                    <div class="w-3 h-3 rounded-full bg-green-400/80"></div>
                    <div class="ml-auto text-xs text-white/30 font-mono">
                        {title.toLowerCase().replace(/\s/g, "-")}.tsx
                    </div>
                </div>

                <div class="space-y-2 font-mono text-xs">
                    <div class="flex gap-2">
                        <span class="text-white/20 select-none">1</span>
                        <span class="text-secondary">import</span>
                        <span class="text-white/70 text-nowrap">{"{ "}{title.replace(" ", "")}{" }"}</span>
                        <span class="text-secondary">from</span>
                        <span class="text-green-400/70"
                            >"@ccsoluciones"</span
                        >
                    </div>
                    <div class="flex gap-2">
                        <span class="text-white/20 select-none">2</span>
                        <span class="text-white/30"
                            >// Desarrollo profesional garantizado</span
                        >
                    </div>
                    <div class="flex gap-2">
                        <span class="text-white/20 select-none">3</span>
                    </div>
                    <div class="flex gap-2">
                        <span class="text-white/20 select-none">4</span>
                        <span class="text-secondary">const</span>
                        <span class="text-blue-300"> proyecto</span>
                        <span class="text-white/70"> = </span>
                        <span class="text-secondary">new</span>
                        <span class="text-white/70"> Proyecto({"{"}</span>
                    </div>
                    <div class="flex gap-2">
                        <span class="text-white/20 select-none">5</span>
                        <span class="text-white/70 pl-4">calidad:</span>
                        <span class="text-green-400/70">"premium"</span>
                        <span class="text-white/70">,</span>
                    </div>
                    <div class="flex gap-2">
                        <span class="text-white/20 select-none">6</span>
                        <span class="text-white/70 pl-4">entrega:</span>
                        <span class="text-green-400/70"
                            >"{timeline || "por hitos"}"</span
                        >
                        <span class="text-white/70">,</span>
                    </div>
                    <div class="flex gap-2">
                        <span class="text-white/20 select-none">7</span>
                        <span class="text-white/70 pl-4">soporte:</span>
                        <span class="text-green-400/70">"24/7"</span>
                    </div>
                    <div class="flex gap-2">
                        <span class="text-white/20 select-none">8</span>
                        <span class="text-white/70">{"}"})</span>
                    </div>
                    <div class="flex gap-2">
                        <span class="text-white/20 select-none">9</span>
                    </div>
                    <div class="flex">
                        <span class="text-white/20 select-none">10</span>
                        <span class="text-white/70 pl-2">proyecto.</span>
                        <span class="text-yellow-300/80">lanzar</span>
                        <span class="text-white/70">()</span>
                        <span class="text-white/30 pl-2">
                            // Tu éxito digital comienza aquí</span
                        >
                    </div>
                </div>
            </div>
        </div>
    </div>


    <style>
        .typewriter-line {
            overflow: hidden;
            white-space: nowrap;
            border-right: 2px solid rgba(255, 255, 255, 0.5); /* cursor */
            width: 0;
            animation:
                typing 2s steps(40, end) forwards,
                blink-caret 0.75s step-end infinite;
        }

        @keyframes typing {
            from {
                width: 0;
            }
            to {
                width: 100%;
            }
        }

        @keyframes blink-caret {
            from,
            to {
                border-color: transparent;
            }
            50% {
                border-color: rgba(255, 255, 255, 0.5);
            }
        }
    </style>
</div>
