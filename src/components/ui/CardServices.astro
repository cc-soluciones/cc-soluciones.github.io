---
import Link from "@/components/ui/Link.astro";
import CodeEditorPanel from "@/components/ui/CodeEditorPanel.astro";
import { contactInfo } from "@/data/contact";

interface Props {
    title?: string;
    descriptions?: string[];
    index?: number;
}

const {
    title = "",
    descriptions = [],
    index = 0,
} = Astro.props as Props;

const formattedIndex = String(index + 1).padStart(2, "0");
---

<div
    class:list={[
        "flex flex-col lg:flex-row gap-12 lg:gap-20 items-center mt-10 reveal opacity-0 transition-all duration-700 ease-out border border-white/10 rounded-3xl px-6 md:px-12 bg-linear-to-tr from-black to-slate-900 h-180",
        "right"
    ]}
>
    <div class="lg:w-1/2 space-y-8 py-12">
        <div class="flex items-center gap-4">
            <span class="text-4xl md:text-6xl font-black text-white/15 leading-none select-none">
                {formattedIndex}
            </span>
            <div class="h-px flex-1 bg-linear-to-r from-white/10 to-transparent"></div>
        </div>

        <div class="space-y-6 flex flex-col justify-center h-120">
            <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-gradient">
                {title}
            </h2>

            <div class="space-y-4">
                {
                    descriptions.map((item) => (
                        <p class="text-base md:text-lg text-zinc-400 leading-[1.8] font-light">
                            {item}
                        </p>
                    ))
                }
            </div>

            <div class="pt-4">
                <Link href={contactInfo.whatsappLink} target="_blank" size="lg">
                    Consultar por este servicio
                </Link>
            </div>
        </div>
    </div>

    <div class="border-l border-white/10 lg:w-1/2 h-full md:flex hidden items-center justify-center pl-12">
        <CodeEditorPanel {title} />
    </div>
</div>
