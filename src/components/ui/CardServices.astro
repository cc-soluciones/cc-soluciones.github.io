---
import Link from "@/components/ui/Link.astro";
import { contactInfo } from "@/data/contact";

interface Props {
    title?: string;
    descriptions?: string[];
    index?: number;
    open?: boolean;
}

const {
    title = "",
    descriptions = [],
    index = 0,
    open = false,
} = Astro.props as Props;

const formattedIndex = String(index + 1).padStart(2, "0");
---

<article class="glass rounded-2xl group/card md:h-150 w-full md:w-auto">
    <div class="hidden md:flex h-full w-24 hover:w-140 transition-all duration-500 ease-out cursor-pointer group">
        <div class="flex flex-col items-center gap-y-6 py-8 w-24 shrink-0">
            <span class="text-2xl font-black text-white/15 leading-none">
                {formattedIndex}
            </span>
            <h3 class="text-4xl font-bold text-gradient [writing-mode:vertical-lr]">
                {title}
            </h3>
        </div>
        <div class="h-full px-8 py-8 space-y-3 flex flex-col justify-between">
            <h3 class="text-4xl font-bold text-gradient">
                {title}
            </h3>
            <div class="space-y-3">
                {descriptions.map((item) => (
                    <p class="text-lg leading-relaxed font-light">
                        {item}
                    </p>
                ))}
            </div>
            <div class="pt-2">
                <Link
                    href={contactInfo.whatsappLink}
                    target="_blank"
                    size="md"
                >
                    Consultar
                </Link>
            </div>
        </div>
    </div>

    <details class="md:hidden group transition-all duration-300 ease-out" {...(open ? { open: "true" } : {})}>
        <summary class="flex items-center gap-3 p-6 cursor-pointer list-none [&::-webkit-details-marker]:hidden select-none">
            <span class="text-2xl font-black text-white/15 leading-none shrink-0">
                {formattedIndex}
            </span>
            <h3 class="text-xl font-bold text-gradient flex-1">{title}</h3>
            <svg
                class="w-5 h-5 text-white/40 transition-transform duration-300 group-open:rotate-180 shrink-0"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
            >
                <polyline points="6 9 12 15 18 9" />
            </svg>
        </summary>
        <div class="px-6 pb-6 space-y-3" data-details-content>
            {descriptions.map((item) => (
                <p class="text-sm text-zinc-400 leading-relaxed font-light">
                    {item}
                </p>
            ))}
            <div class="pt-2">
                <Link
                    href={contactInfo.whatsappLink}
                    target="_blank"
                    size="md"
                >
                    Consultar
                </Link>
            </div>
        </div>
    </details>
</article>
