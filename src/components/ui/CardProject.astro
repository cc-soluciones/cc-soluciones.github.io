---
import type { Project } from "@/data/projects";

interface Props {
	project: Project;
}

const { project } = Astro.props as Props;
---

<a
	href={project.url}
	target="_blank"
	class="glass rounded-2xl overflow-hidden group"
>
	<div class="aspect-video overflow-hidden">
		<img
			class="w-full h-full object-cover transition-all duration-500 group-hover:scale-105"
			style={`object-position: ${project.images[0]?.position || "50% 50%"}`}
			src={project.images[0]?.src}
			alt={`Captura de ${project.title}`}
			loading="lazy"
		/>
	</div>
	<div class="p-5 flex items-center justify-between">
		<h3 class="text-lg font-bold tracking-tight uppercase">
			{project.title}
		</h3>
		<!-- <Arrow class="w-5 h-5 text-secondary transition-transform duration-300 group-hover:translate-x-1" /> -->
	</div>
</a>
