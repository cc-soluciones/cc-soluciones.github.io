---
import Link from "@/components/ui/Link.astro";
import Arrow from "@/components/svg/Arrow.astro";
import ProjectImage from "@/components/ui/ProjectImage.astro";
import { projects } from "@/data/projects";
---

{projects.map((item, index) => (
    <div class="relative flex flex-wrap md:gap-y-25 overflow-hidden md:overflow-visible card-wrapper" data-key={index}>
        <div class="w-full mb-10 md:mb-0 pt-10 flex justify-center project-title">
            <Link href={item.url} target="_blank" class="text-lg md:text-2xl font-bold tracking-tight text-center flex gap-2 justify-center items-center px-10 uppercase">
                <span>{item.title}</span> <Arrow class="mt-1 ml-1"/>
            </Link>
        </div>
        <div class="relative w-screen overflow-hidden feature-imgs feature-img-h">
            <div class="absolute left-[50%] translate-x-[-50%]">
                <div class="flex flex-row justify-center items-center gap-3.75">
                    {[0, 1, 2].map((imgIndex) => (
                        <ProjectImage
                            src={item.images[imgIndex].src}
                            position={item.images[imgIndex].position || "0% 0%"}
                            imgIndex={imgIndex}
                        />
                    ))}
                </div>
            </div>
        </div>
    </div>
))}

<style>
    .slide-up-fade {
        animation: slideUpFade 0.6s ease-out forwards;
    }

    @keyframes slideUpFade {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 0.8;
            transform: translateY(0);
        }
    }

    .feature-img, [data-box] {
        opacity: 0.8;
        transition:
            opacity 0.5s ease,
            transform 0.5s ease;
    }

    .sliding {
        opacity: 0;
        transform: translateY(-20px);
    }
</style>

<script>
    import { initProjectCarousel } from "@/scripts/projectCarousel";
    import { projects } from "@/data/projects";

    initProjectCarousel({ projects });
</script>
