---
import { t } from "@/lib/i18n";
import type { Lang } from "@/data/i18n";

interface Props {
    lang: Lang;
}

const { lang } = Astro.props;
---

<button
    id="theme-toggle"
    class="relative w-10 h-10 flex items-center justify-center rounded-xl bg-white/5 dark:bg-white/5 border border-white/10 dark:border-white/10 backdrop-blur-xl cursor-pointer transition-all duration-300 hover:bg-white/10 hover:border-primary/30 hover:shadow-lg hover:shadow-primary/10 group"
    aria-label={t(lang, "theme.dark")}
>
    <svg class="w-5 h-5 text-foreground hidden dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="5"/>
        <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
    </svg>
    <svg class="w-5 h-5 text-foreground block dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
    </svg>
</button>

<script>
    import { store } from "@/lib/store";

    const btn = document.getElementById("theme-toggle")!;
    btn.addEventListener("click", () => store.toggleTheme());
    store.subscribe(() => {
        const isDark = store.getTheme() === "dark";
        btn.querySelector("svg.hidden")?.classList.toggle("hidden", !isDark);
        btn.querySelector("svg.block")?.classList.toggle("hidden", isDark);
        btn.querySelector("svg.block")?.classList.toggle("block", !isDark);
    });
</script>
