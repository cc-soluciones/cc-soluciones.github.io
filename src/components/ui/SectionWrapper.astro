---
interface Props {
    id?: string;
    class?: string;
    blobs?: ("tl" | "tr" | "bl" | "br" | "center")[];
    [key: string]: any;
}

const { id, blobs = [], ...rest } = Astro.props;

const blobPositions: Record<string, string> = {
    tl: "top-0 left-0 w-[400px] h-[400px] rounded-full bg-gradient-to-br from-secondary/10 via-primary/5 to-transparent blur-[100px]",
    tr: "top-0 right-0 w-[400px] h-[400px] rounded-full bg-gradient-to-bl from-secondary/10 via-primary/5 to-transparent blur-[100px]",
    bl: "bottom-0 left-0 w-[400px] h-[400px] rounded-full bg-gradient-to-tr from-accent/10 via-primary/5 to-transparent blur-[100px]",
    br: "bottom-0 right-0 w-[400px] h-[400px] rounded-full bg-gradient-to-tl from-primary/15 via-secondary/10 to-transparent blur-[120px]",
    center: "top-1/3 left-1/2 -translate-x-1/2 w-[500px] h-[500px] rounded-full bg-gradient-to-b from-secondary/8 via-primary/5 to-transparent blur-[120px]",
};
---

<section id={id} class={`relative py-24 sm:py-32 overflow-hidden ${Astro.props.class || ""}`} {...rest}>
    <div class="absolute inset-0 pointer-events-none">
        {blobs.map((pos) => (
            <div class={`absolute ${blobPositions[pos]}`} />
        ))}
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <slot />
    </div>
</section>
