---
interface Props {
    text: string;
    variant?: "section" | "light";
}

const { text, variant = "section" } = Astro.props;
---

{
    variant === "section" ? (
        <span class="inline-block px-5 py-1.5 rounded-full text-xs font-medium tracking-wider uppercase text-secondary border border-secondary/20 bg-secondary/5">
            {text}
        </span>
    ) : (
        <span class="inline-flex items-center rounded-full border border-white/10 px-4 py-2 text-sm font-medium">
            {text}
        </span>
    )
}
