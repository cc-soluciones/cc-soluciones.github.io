---
import { Icon } from "astro-icon/components";

interface Props {
    icon?: string;
    iconClass?: string;
    dot?: "green" | "yellow" | "red";
    class?: string;
}

const { icon, iconClass = "", dot } = Astro.props;

const dotColors: Record<string, string> = {
    green: "bg-green-400 bg-green-500",
    yellow: "bg-yellow-400 bg-yellow-500",
    red: "bg-red-400 bg-red-500",
};
---

<div class="inline-flex items-center gap-1.5 rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[10px] font-medium tracking-wide text-foreground-secondary backdrop-blur-sm {Astro.props.class || ''}">
    {dot && (
        <span class="relative flex h-2 w-2">
            <span class={`animate-ping absolute inline-flex h-full w-full rounded-full opacity-75 ${dotColors[dot].split(" ")[0]}`} />
            <span class={`relative inline-flex rounded-full h-2 w-2 ${dotColors[dot].split(" ")[1]}`} />
        </span>
    )}
    {icon && <Icon name={icon} class={`w-3 h-3 ${iconClass || "text-foreground-secondary"}`} aria-hidden="true" />}
    <slot />
</div>
