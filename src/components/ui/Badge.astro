---
import { Icon } from "astro-icon/components"

export interface Props {
    class?: string
    icon?: string
}

const { class: className = "", icon } = Astro.props
---

<span class={`inline-flex items-center gap-2 rounded-full border border-border bg-foreground/5 backdrop-blur-md px-3 py-1.5 transition-colors hover:bg-foreground/10 ${className}`.trim()}>
    <span class="flex items-center gap-2 text-[10px] sm:text-xs font-semibold uppercase tracking-wider text-foreground/70">
        <slot />
        {icon && <Icon name={icon} class="w-3.5 h-3.5" />}
    </span>
</span>
