---
import { Icon } from "astro-icon/components";

export interface Props {
    icon?: string;
}

const { 
    icon 
} = Astro.props as Props;
---

<span class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-3 py-1.5 backdrop-blur-md transition-colors hover:bg-white/10">
    <span class="flex items-center gap-2 text-[10px] sm:text-xs font-semibold uppercase tracking-wider text-foreground/70">
        <slot />
        {icon && <Icon name={icon} class="w-3.5 h-3.5" />}
    </span>
</span>
