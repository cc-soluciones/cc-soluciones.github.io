---
interface Props {
    padding?: "sm" | "md" | "lg";
    hover?: boolean;
    class?: string;
    [key: string]: any;
}

const { padding = "md", hover = false, ...rest } = Astro.props;

const paddingClasses: Record<string, string> = {
    sm: "p-4 sm:p-5",
    md: "p-6 sm:p-8",
    lg: "p-8 sm:p-10",
};

const hoverClasses = hover
    ? "transition-all duration-500 hover:bg-white/[0.08] hover:border-primary/20 hover:shadow-xl hover:shadow-primary/5"
    : "";
---

<div
    class={`relative overflow-hidden rounded-3xl border border-white/10 bg-gradient-to-b from-white/[0.06] to-white/[0.02] backdrop-blur-xl shadow-2xl ${paddingClasses[padding]} ${hoverClasses} ${Astro.props.class || ""}`}
    {...rest}
>
    <div class="absolute top-0 right-0 -mr-16 -mt-16 h-64 w-64 rounded-full bg-primary/5 blur-3xl pointer-events-none" />
    <div class="relative z-10">
        <slot />
    </div>
</div>
