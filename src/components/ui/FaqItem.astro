---
import { Icon } from "astro-icon/components";

interface Props {
	question: string;
	answer: string;
	index: number;
}

const { question, answer, index } = Astro.props;
---

<details
	class="group border-b border-white/10 transition-all duration-300 has-[open]:border-secondary/30"
	style={`transition-delay: ${index * 50}ms`}
>
	<summary class="w-full flex items-center justify-between p-5 md:p-6 text-left cursor-pointer list-none [&::-webkit-details-marker]:hidden">
		<span class="text-base md:text-lg font-semibold pr-4 text-white/90">
			{question}
		</span>
		<span class="shrink-0 w-8 h-8 rounded-full border border-white/10 flex items-center justify-center bg-white/5 transition-rotate duration-300 group-has-[open]:rotate-180">
			<Icon name="mdi:chevron-down" class="w-4 h-4" />
		</span>
	</summary>
	<div class="px-5 md:px-6 pb-5 md:pb-6">
		<div class="pt-2">
			<p class="text-slate-400 leading-relaxed text-base pt-4">
				{answer}
			</p>
		</div>
	</div>
</details>
