---
import { Icon } from "astro-icon/components";

import Link from "@/components/ui/Link.astro";

import { siteConfig } from "@/data/site";
import { navConfig } from "@/data/site";
import { contactInfo } from "@/data/contact";
---

<nav
    class="fixed z-200 left-1/2 -translate-x-1/2 flex items-center justify-between w-[calc(100%-2rem)] md:min-w-7xl md:w-auto px-6 py-3 rounded-full text-sm mt-2 backdrop-blur-md backdrop-saturate-150 border border-stone-800 bg-background/20"
>
    <Link href="/" class="text-lg font-bold">
        <img
			class="object-cover transition-all duration-500 group-hover:scale-105 w-8 h-8"
			alt={siteConfig.company}
			src={siteConfig.logo}
			loading="lazy"
		/>
    </Link>
    <div class="text-2xl font-black tracking-tighter md:hidden">
        {siteConfig.company.split(" ")[0]} <span class="text-gradient-secondary">{siteConfig.company.split(" ")[1]}</span>
    </div>
    <div class="hidden md:flex items-center gap-6">
        {
            navConfig.map((item) => (
                <a href={item.href} data-id={item.href.replace("#", "")} class="relative overflow-hidden h-5 group nav-link">
                    <span class="block group-hover:-translate-y-full transition-transform duration-300">
                        {item.label}
                    </span>
                    <span class="block absolute top-full left-0 roup-hover:-translate-y-full transition-transform duration-300">
                        {item.label}
                    </span>
                </a>
            ))
        }
    </div>
    <Link class="hidden md:flex items-center gap-4" href={contactInfo.whatsappLink} target="_blank">
        Contáctanos
    </Link>
    <button id="menuToggle" class="md:hidden text-foreground">
        <Icon name="mdi:menu" class="w-10 h-10" />
    </button>
</nav>
<div
    id="mobileMenu"
    class="fixed left-1/2 -translate-x-1/2 hidden top-24 w-[calc(100%-2.5rem)] flex-col items-center gap-10 rounded-xl border border-stone-800 bg-background/30 py-4 backdrop-blur-md backdrop-saturate-150 z-100"
>
    {navConfig.map((item) => (
        <a class="nav-link text-2xl" href={item.href} data-id={item.href.replace("#", "")}>
            {item.label}
        </a>
    ))}
    <Link size="xl" href={contactInfo.whatsappLink} target="_blank">
        Contáctanos
    </Link>
</div>
