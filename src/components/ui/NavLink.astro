---
interface Props {
	href: string;
	label: string;
}

const { href, label } = Astro.props;
const dataId = href.replace("#", "");
---

<a
	href={href}
	data-id={dataId}
	class="relative overflow-hidden h-5 group nav-link"
>
	<span class="block group-hover:-translate-y-full transition-transform duration-300">
		{label}
	</span>
	<span class="block absolute top-full left-0 group-hover:-translate-y-full transition-transform duration-300">
		{label}
	</span>
</a>
