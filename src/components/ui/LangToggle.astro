---
import { t } from "@/lib/i18n";
import type { Lang } from "@/data/i18n";

interface Props {
    lang: Lang;
}

const { lang: currentLang } = Astro.props;
---

<button
    id="lang-toggle"
    class="relative px-3 h-10 flex items-center gap-2 rounded-xl bg-white/5 dark:bg-white/5 border border-white/10 dark:border-white/10 backdrop-blur-xl cursor-pointer transition-all duration-300 hover:bg-white/10 hover:border-primary/30 hover:shadow-lg hover:shadow-primary/10 font-medium text-sm text-foreground group"
    aria-label={t(currentLang, "lang.switch")}
>
    <span class="w-5 h-5 rounded-full overflow-hidden flex-shrink-0">
        {currentLang === "es" ? (
            <svg viewBox="0 0 640 480" class="w-full h-full"><path fill="#0039A6" d="M0 0h640v480H0z"/><path fill="#FFF" d="M0 0h640v320H0z"/><path fill="#D52B1E" d="M0 0h640v160H0z"/></svg>
        ) : (
            <svg viewBox="0 0 640 480" class="w-full h-full"><path fill="#012169" d="M0 0h640v480H0z"/><path fill="#FFF" d="m0 0 320 240L640 0v480L320 240 0 480z"/><path fill="#C8102E" d="m0 0 320 240L640 0v480L320 240 0 480z" stroke-width="60"/></svg>
        )}
    </span>
    <span class="hidden sm:inline">{currentLang === "es" ? "ES" : "EN"}</span>
</button>

<script>
    import { store } from "@/lib/store";
    import type { Lang } from "@/data/i18n";

    const btn = document.getElementById("lang-toggle")!;
    btn.addEventListener("click", () => {
        const newLang: Lang = store.getLang() === "es" ? "en" : "es";
        store.setLang(newLang);
        window.location.reload();
    });
</script>
