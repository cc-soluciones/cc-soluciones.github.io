---
import { Icon } from "astro-icon/components"

export interface Props {
    class?: string
    variant?: "primary" | "outline" | "ghost"
    size?: "sm" | "md" | "lg"
    href?: string
    icon?: string
}

const {
    class: className = "",
    variant = "primary",
    size = "md",
    href,
    icon,
} = Astro.props

const base = "group inline-flex items-center justify-center gap-2 rounded-full font-semibold transition-all whitespace-nowrap"
const variants = {
    primary: "bg-primary text-foreground hover:scale-[1.02] hover:brightness-110 active:scale-[0.98] shadow-lg shadow-primary/25",
    outline: "border border-border bg-foreground/5 backdrop-blur-sm text-foreground hover:bg-foreground/10 active:scale-[0.98]",
    ghost: "text-foreground/70 hover:text-foreground hover:bg-foreground/5 active:scale-[0.98]",
}
const sizes = {
    sm: "px-4 py-2 text-xs tracking-wide",
    md: "px-6 py-3 text-sm tracking-wide",
    lg: "px-8 py-4 text-sm tracking-wide",
}

const cls = `${base} ${variants[variant]} ${sizes[size]} ${className}`.trim()
const Tag = href ? "a" : "button"
---

<Tag href={href} class={cls}>
    {icon && (
        <Icon
            name={icon}
            class="w-4 h-4 transition-transform group-hover:translate-x-0.5"
        />
    )}
    <slot />
</Tag>
