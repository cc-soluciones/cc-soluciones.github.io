---
import { sizeClasses } from "@/lib/sizeClasses";
import type { Size } from "@/lib/sizeClasses";

interface Props {
    size?: Size;
}

const { size = "md" } = Astro.props as Props;
---

<button
    class={`bg-white text-black rounded-full font-medium hover:bg-white/90 transition-all duration-200 cursor-pointer ${sizeClasses[size]}`}
>
    <slot />
</button>
