---
import { Icon } from "astro-icon/components";

interface Props {
    icon: string;
    size?: "sm" | "md" | "lg";
    class?: string;
}

const { icon, size = "md" } = Astro.props;

const sizes: Record<string, string> = {
    sm: "w-10 h-10 rounded-lg",
    md: "w-12 h-12 rounded-xl",
    lg: "w-16 h-16 rounded-2xl",
};

const iconSizes: Record<string, string> = {
    sm: "w-5 h-5",
    md: "w-6 h-6",
    lg: "w-7 h-7",
};
---

<div class={`${sizes[size]} bg-gradient-to-br from-primary/20 to-secondary/20 flex items-center justify-center flex-shrink-0 transition-transform duration-300 group-hover:scale-110 ${Astro.props.class || ""}`}>
    <Icon name={icon} class={`${iconSizes[size]} text-primary`} />
</div>
