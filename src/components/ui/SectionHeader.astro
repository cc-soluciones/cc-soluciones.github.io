---
interface Props {
    badge: string;
    title: string;
    highlight: string;
    description: string;
    gradient?: "primary-secondary" | "primary-accent" | "secondary-accent" | "accent-primary-secondary";
    class?: string;
}

const { badge, title, highlight, description, gradient = "primary-secondary" } = Astro.props;

const gradientClasses: Record<string, string> = {
    "primary-secondary": "from-primary to-secondary",
    "primary-accent": "from-primary to-accent",
    "secondary-accent": "from-secondary to-accent",
    "accent-primary-secondary": "from-accent via-primary to-secondary",
};
---

<div class={`max-w-2xl mx-auto text-center mb-16 ${Astro.props.class || ""}`}>
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/5 border border-white/10 backdrop-blur-xl mb-6">
        <span class="text-xs font-medium text-foreground-secondary tracking-wider uppercase">
            {badge}
        </span>
    </div>
    <h2 class="text-3xl sm:text-4xl font-bold text-foreground mb-4">
        {title}{" "}
        <span class={`bg-gradient-to-r ${gradientClasses[gradient]} bg-clip-text text-transparent`}>
            {highlight}
        </span>
    </h2>
    <p class="text-foreground-secondary leading-relaxed">
        {description}
    </p>
</div>
