---
import Link from "@/components/ui/Link.astro";
import { whatsappLink } from "@/constants/general";

interface Props {
    id?: string;
}

const { id = "" } = Astro.props as Props;
---
<section id={id} class="max-w-7xl my-40 w-full pt-30 px-6" data-animation="footer">
    <div class="reveal opacity-0 translate-y-12 transition-all duration-700 ease-out p-12 rounded-[2.5rem] text-center space-y-10 relative overflow-hidden border border-stone-800 backdrop-blur-md backdrop-saturate-150">
        <div class="absolute top-0 right-0 w-full h-100 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/2 blur-3xl"/>
        <h3 class="text-3xl md:text-5xl font-bold tracking-tight">
            ¿Tienes un proyecto en mente?
        </h3>
        <p class="text-slate-400 max-w-xl mx-auto md:text-xl text-lg leading-relaxed">
            Estamos listos para ayudarte a construir el futuro de tu empresa.
            Hablemos sobre cómo podemos escalar tu visión.
        </p>
        <div class="pt-4">
            <Link size="xl" href={whatsappLink} target="_blank">
                Contactanos
            </Link>
        </div>
    </div>
</section>
